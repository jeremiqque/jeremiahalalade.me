---

<nav class="dock" aria-label="Social links">
  <div class="pill">
    {links.map((l) => (
      <a class="item" href={l.href} target="_blank" rel="noopener noreferrer" aria-label={l.label}>
        <svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor" aria-hidden="true">
          <path d={l.path} />
        </svg>
      </a>
    ))}

    <span class="divider" aria-hidden="true"></span>

    <a class="book" href={chatHref} target="_blank" rel="noopener noreferrer">Book me</a>
  </div>
</nav>

<style>
  .dock {
    position: fixed;
    /* stays pinned to the bottom of the viewport on every device, clearing
       the phone home-bar / safe area */
    bottom: calc(28px + env(safe-area-inset-bottom, 0px));
    left: 50%;
    transform: translateX(-50%);
    z-index: 99999;
    display: flex;
    align-items: center;
    max-width: calc(100vw - 20px);
  }

  @media (max-width: 560px) {
    .dock { bottom: calc(18px + env(safe-area-inset-bottom, 0px)); }
  }

  .pill {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 8px 12px;
    border-radius: 999px;
    background: var(--dock-bg, rgba(36, 36, 38, 0.97));
    border: 1px solid var(--dock-border, rgba(255, 255, 255, 0.07));
    box-shadow: var(--dock-shadow);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    /* never clip: if it can't fit, allow a quiet horizontal scroll */
    max-width: 100%;
    overflow-x: auto;
    scrollbar-width: none;
    transition: background-color 0.3s ease, border-color 0.3s ease,
      box-shadow 0.3s ease;
  }
  .pill::-webkit-scrollbar { display: none; }

  /* thin vertical separators, like geeboy.me */
  .divider {
    flex: none;
    width: 1px;
    align-self: stretch;
    margin: 4px 2px;
    background: var(--dock-divider, rgba(255, 255, 255, 0.1));
  }

  /* ----- Icon tile (orevbajohn.me interaction: scale + dim siblings) ----- */
  .item {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 40px;
    border-radius: 12px;
    color: var(--dock-icon, rgba(255, 255, 255, 0.9));
    text-decoration: none;
    background: transparent;
    opacity: 1;
    transition: transform 0.2s cubic-bezier(0.2, 0, 0, 1),
      opacity 0.22s cubic-bezier(0.2, 0, 0, 1), color 0.22s ease,
      background-color 0.2s ease;
  }
  /* hovering the pill dims every icon; the hovered one lifts back up */
  .pill:hover .item { opacity: 0.28; }
  .pill .item:hover {
    opacity: 1;
    color: var(--dock-icon-hover, #fff);
    background: var(--dock-item-hover, rgba(255, 255, 255, 0.09));
    transform: scale(1.12);
    transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 0.22s cubic-bezier(0.2, 0, 0, 1), color 0.22s ease,
      background-color 0.2s ease;
  }
  .item:active {
    transform: scale(0.96);
    transition: transform 0.1s cubic-bezier(0.2, 0, 0, 1);
  }
  .item svg { display: block; }

  /* ----- "Book me" button (inverts on hover, presses on active) ----- */
  .book {
    flex: none;
    display: inline-flex;
    align-items: center;
    margin-left: 3px;
    padding: 9px 18px;
    border-radius: 999px;
    border: 1px solid var(--dock-book-border, rgba(255, 255, 255, 0.12));
    color: var(--dock-book-text, #fff);
    background: transparent;
    font-family: var(--font-body, sans-serif);
    font-size: 14px;
    line-height: 1.4;
    white-space: nowrap;
    text-decoration: none;
    transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease,
      transform 0.15s ease;
  }
  .book:hover {
    background: var(--dock-book-hover-bg, #fff);
    color: var(--dock-book-hover-text, #000);
    border-color: var(--dock-book-hover-bg, #fff);
  }
  .book:active { transform: scale(0.93); }

  .item:focus-visible,
  .book:focus-visible {
    outline: 2px solid var(--dock-icon-hover, #fff);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .pill:hover .item { opacity: 1; }
    .pill .item:hover { transform: none; }
    .item:active, .book:active { transform: none; }
  }

  /* Tighten the dock on small screens so all icons + dividers + button fit. */
  @media (max-width: 560px) {
    .divider { margin: 4px 1px; }
    .pill { gap: 3px; padding: 6px 8px; }
    .item { width: 36px; height: 34px; }
  }
  @media (max-width: 400px) {
    .pill { gap: 1px; padding: 5px 6px; }
    .divider { margin: 4px 0; }
    .item { width: 30px; height: 30px; }
    .item svg { width: 15px; height: 15px; }
    .book { margin-left: 2px; padding: 6px 10px; font-size: 12px; }
  }
</style>
