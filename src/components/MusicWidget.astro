---
// Live "now playing / last listened" music card.
// Matches Figma node 290-124: lighter #2E2E2E shell, inner #202020 panel,
// square album art, vinyl icon footer. When a track is actively playing it
// switches to the "Listening now" state: animated equalizer bars + red dot.
// Pulls real data from /api/spotify on the client.
const PLACEHOLDER_ART = "/assets/album.svg";

// Deterministic per-bar timing so the equalizer looks lively but stable.
const BARS = Array.from({ length: 22 }, (_, i) => ({
  delay: ((i * 0.13) % 0.9).toFixed(2),
  dur: (0.6 + ((i * 7) % 6) * 0.09).toFixed(2),
}));
---

<div class="music" data-music>
  <div class="mw-card">
    <div class="mw-panel">
      <img
        class="mw-art"
        data-art
        src={PLACEHOLDER_ART}
        alt="Album artwork"
        width="93"
        height="93"
        draggable="false"
      />
      <div class="mw-meta">
        <a class="mw-title" data-title href="#">Loading…</a>
        <p class="mw-artist" data-artist>&nbsp;</p>
      </div>

      <div class="mw-viz" data-viz aria-hidden="true">
        {BARS.map((b) => <i style={`animation-delay:${b.delay}s;animation-duration:${b.dur}s`}></i>)}
      </div>
    </div>

    <div class="mw-footer">
      <span class="mw-status" aria-hidden="true">
        <svg class="mw-vinyl" viewBox="0 0 24 24" width="22" height="22" fill="none">
          <path d="M22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12Z" stroke="currentColor" stroke-width="1.5"/>
          <path d="M9 6C7.62837 6.53566 6.53566 7.62837 6 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M14 12C14 10.8954 13.1046 10 12 10C10.8954 10 10 10.8954 10 12C10 13.1046 10.8954 14 12 14C13.1046 14 14 13.1046 14 12Z" stroke="currentColor" stroke-width="1.5"/>
        </svg>
      </span>
      <span class="mw-last" data-last>Fetching your music…</span>
    </div>
  </div>
</div>

<script is:inline define:vars={{ PLACEHOLDER_ART }}>
  const root = document.querySelector("[data-music]");
  if (root) {
    const els = {
      art: root.querySelector("[data-art]"),
      title: root.querySelector("[data-title]"),
      artist: root.querySelector("[data-artist]"),
      last: root.querySelector("[data-last]"),
    };

    async function fetchSpotify() {
      try {
        const res = await fetch(`/api/spotify?t=${Date.now()}`);
        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          throw new Error(err.error || `Request failed (${res.status})`);
        }
        const song = await res.json();

        els.art.src = song.albumArtUrl || PLACEHOLDER_ART;
        els.art.alt = `Album artwork for ${song.title} by ${song.artists}`;
        els.title.textContent = song.title;
        els.title.href = song.songUrl || "#";
        els.artist.textContent = song.artists;
        els.last.textContent = song.isPlaying ? "Listening now" : song.lastPlayed;
        root.classList.toggle("is-playing", !!song.isPlaying);
      } catch (e) {
        els.title.textContent = "Unable to load music";
        els.title.removeAttribute("href");
        els.artist.textContent = "";
        els.last.textContent = e instanceof Error ? e.message : "Try again later.";
        root.classList.remove("is-playing");
      }
    }

    fetchSpotify();
    // Refresh every 20s, only while the tab is visible (snappier "now playing").
    setInterval(() => {
      if (!document.hidden) fetchSpotify();
    }, 20000);
    document.addEventListener("visibilitychange", () => {
      if (!document.hidden) fetchSpotify();
    });
  }
</script>

<style>
  .music {
    width: 100%;
    max-width: none;
    font-family: var(--font-body, sans-serif);
  }

  /* Outer shell (#2E2E2E) */
  .mw-card {
    background: var(--mw-shell, #2e2e2e);
    border-radius: 0;
    padding: clamp(12px, 1.4vw, 17px) clamp(16px, 2vw, 27px);
    display: flex;
    flex-direction: column;
    gap: clamp(8px, 1vw, 12px);
    transition: background-color 0.3s ease;
  }

  /* Inner panel */
  .mw-panel {
    background: var(--mw-panel, #202020);
    border-radius: 0;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: clamp(9px, 1.1vw, 12px);
  }

  .mw-art {
    flex: none;
    height: clamp(72px, 8.5vw, 93px);
    width: clamp(72px, 8.5vw, 93px);
    border-radius: 0;
    object-fit: cover;
    background: #d9d9d9;
  }

  .mw-meta {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .mw-title {
    color: var(--mw-title, #f2f2f2);
    font-size: clamp(1.15rem, 1.5vw, 1.4rem);
    font-weight: 600;
    line-height: 1.15;
    text-decoration: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .mw-title:hover { text-decoration: underline; text-underline-offset: 3px; }

  .mw-artist {
    margin: 0;
    color: var(--mw-artist, #c9c9c9);
    font-size: clamp(0.95rem, 1.1vw, 1.05rem);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ----- Equalizer (only while playing) ----- */
  .mw-viz {
    flex: none;
    display: none;          /* shown via .is-playing */
    align-items: center;
    gap: 3px;
    height: 36px;
    padding-right: clamp(6px, 1vw, 16px);
  }
  .mw-viz i {
    display: block;
    width: 3px;
    height: 100%;
    border-radius: 2px;
    background: #f0500c;
    transform: scaleY(0.28);
    transform-origin: center;
    animation-name: mw-eq;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
  }
  @keyframes mw-eq {
    0%, 100% { transform: scaleY(0.28); }
    50%      { transform: scaleY(1); }
  }

  /* ----- Footer (vinyl/dot + status text) ----- */
  .mw-footer {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 2px clamp(2px, 0.5vw, 6px) 2px;
    color: var(--mw-footer, #f2f2f2);
    font-size: clamp(0.9rem, 1vw, 1rem);
  }

  .mw-status {
    flex: none;
    display: inline-flex;
    align-items: center;
    color: var(--mw-footer, #f2f2f2);
  }
  .mw-vinyl {
    display: inline-block;
    transition: color 0.25s ease;
  }

  .mw-last {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  /* ----- Playing state ----- */
  .music.is-playing .mw-viz { display: flex; }
  .music.is-playing .mw-vinyl {
    color: #f0500c;
    animation: mw-spin 3.2s linear infinite;
  }
  @keyframes mw-spin {
    to { transform: rotate(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .mw-viz i { animation: none; transform: scaleY(0.6); }
    .music.is-playing .mw-vinyl { animation: none; }
  }
</style>
